{
  "name": "anilibrix-plus",
  "version": "1.0.0",
  "description": "Anilibrix Plus — desktop client for watching anime built with Electron, Vue 3, and Material Design 3",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "discord-rpc": "^4.0.1",
    "electron-store": "^8.2.0",
    "gsap": "^3.12.5",
    "hls.js": "^1.6.16",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.3.0",
    "electron-builder": "^24.13.3",
    "sass": "^1.75.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "tv.anilibrixplus.desktop",
    "productName": "Anilibrix Plus",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
